{
  "name": "bemused-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "npm run build && ./scripts/deploy.sh",
    "mbid-lookup": "tsx scripts/mbid-lookup.ts",
    "image-lookup": "tsx scripts/image-lookup.ts",
    "similar-artists": "tsx scripts/similar-artists.ts",
    "diagnose-similar": "tsx scripts/diagnose-similar.ts",
    "worker": "tsx watch src/workers/queue-handler.ts",
    "db:snapshot": "mkdir -p snapshots && pg_dump bemused_dev > snapshots/$(date +%Y%m%d_%H%M%S).sql && echo 'Snapshot saved to snapshots/'",
    "db:restore": "bash scripts/db-restore.sh",
    "db:schema:dump": "pg_dump --schema-only --no-owner --no-privileges $BEMUSED_DB > schema.sql && echo 'Schema dumped to schema.sql'",
    "db:reset": "bash scripts/db-reset.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.27.0",
    "music-metadata": "^11.12.3",
    "node-fetch": "^3.3.2",
    "node-id3": "^0.2.9",
    "pg": "^8.13.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}
