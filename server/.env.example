# Local development — copy this to .env and fill in values

NODE_ENV=development

# Local PostgreSQL database (created by scripts/setup-local-dev.sh)
BEMUSED_DB=postgres://localhost/bemused_dev

# Port for the API server (Vite proxies /api to this in dev)
PORT=3000

# Leave empty in dev — server generates http://localhost:PORT stream URLs
# Set to https://patf.com/bemused in production
BEMUSED_PATH=

# Directory where processed audio files are stored after upload
# In production this is an fstab-mounted NAS path
# Locally: created by scripts/setup-local-dev.sh
BEMUSED_UPLOAD_PATH=/home/pfarrell/bemused-dev/music

# Uncomment to proxy audio streams to production instead of serving local files
# Useful if you don't have local music files yet
# BEMUSED_DEV=https://patf.net/bemused

# API keys — get your own at last.fm/api and fanart.tv
LASTFM_API_KEY=your_lastfm_api_key_here
FANART_API_KEY=your_fanart_api_key_here
