BEMUSED_DB=postgres://user:password@localhost:5432/bemused
PORT=3000
# Full base URL for stream links in track responses.
# Dev: leave empty — stream URLs will be http://localhost:PORT/stream/:id
# Prod: set to the public base URL — stream URLs will be https://patf.com/bemused/stream/:id
BEMUSED_PATH=https://patf.com/bemused
# Set this in dev when the NAS is unavailable — proxies streams to production
# BEMUSED_DEV=https://patf.net/bemused
